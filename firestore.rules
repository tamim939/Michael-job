rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, role, isActive, status, createdAt
    //
    // Collection: jobs
    // Fields: title, description, reward, createdAt, createdBy
    //
    // Collection: activationRequests
    // Fields: userId, userEmail, transactionId, method, status, createdAt
    //
    // Collection: settings
    // Fields: bikashNumber, nagadNumber, activationFee, minWithdraw
    //
    // Collection: withdrawals
    // Fields: userId, userEmail, amount, method, number, status, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email in ["rsjonayed07@gmail.com", "tamimhh@gmail.com", "tamim@gmail", "tamimhht@gmail.com"] && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'isActive', 'status', 'balance']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.isActive is bool &&
             data.status in ['none', 'pending', 'active', 'rejected'] &&
             data.balance is number;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['title', 'description', 'reward', 'createdAt', 'createdBy']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 &&
             data.reward is number && data.reward >= 0 &&
             data.createdBy is string &&
             (!('link' in data) || data.link is string) &&
             (!('imageUrl' in data) || data.imageUrl is string);
    }

    function isValidActivationRequest(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'transactionId', 'method', 'status', 'createdAt']) &&
             data.userId is string &&
             data.userEmail is string &&
             data.transactionId is string && data.transactionId.size() > 0 &&
             data.method is string &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['jobId', 'jobTitle', 'userId', 'userEmail', 'proofText', 'proofImage', 'reward', 'status', 'createdAt']) &&
             data.jobId is string &&
             data.jobTitle is string &&
             data.userId is string &&
             data.userEmail is string &&
             data.proofText is string && data.proofText.size() > 0 &&
             data.proofImage is string && data.proofImage.size() > 0 &&
             data.reward is number &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'amount', 'method', 'number', 'status', 'createdAt']) &&
             data.userId is string &&
             data.userEmail is string &&
             data.amount is number && data.amount > 0 &&
             data.method in ['bikash', 'nagad'] &&
             data.number is string && data.number.size() >= 11 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == 'user' && 
                      request.resource.data.status == 'none' &&
                      request.resource.data.balance == 0;
      allow update: if isAdmin() || (isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.status == resource.data.status &&
                      request.resource.data.balance == resource.data.balance);
    }

    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidJob(request.resource.data);
    }

    match /activationRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                      isValidActivationRequest(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidActivationRequest(request.resource.data);
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                      isValidSubmission(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidSubmission(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                      isValidWithdrawal(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidWithdrawal(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
